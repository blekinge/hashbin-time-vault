#!/usr/bin/env python3
"""hashbin — Linux CLI for hashbin.net trusted file timestamping.

Usage:
    hashbin stamp <file> [<file>...]  [--include-name] [--token TOKEN]
    hashbin verify <file-or-hash>     [--algorithm ALGO]
    hashbin health

No external dependencies — Python 3.8+ standard library only.
"""

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.request
import urllib.error

